      "seed": 377347610,
      "version": 848,
      "versionNonce": 1749045722,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771955200419,
      "link": null,
      "locked": false,
      "text": "CREATE EXECUTION PLAN\n\n- Show the title/description\n- Execution plan will be created after the\nResources were loaded\n- show the names of the resources in this\nplan card\n- Allow to switch the workspace\n- Genereate an detailed execution plan\naccording to the {System Prompt|AI\nPersonality|Custom\nPrompt|UserPrompt|Confirmation Wuestions}\n- Capture the timestamp of the creation and\nsave this\n- Allow the user to add more resources\n- Allow to select the research template\n- Also pickup the user BIO to generate the\nresearch customized (if allowed)\n",
      "fontSize": 16,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "ue1I-b71lkcDvviM6iQt9",
      "originalText": "CREATE EXECUTION PLAN\n\n- Show the title/description\n- Execution plan will be created after the Resources were loaded\n- show the names of the resources in this plan card\n- Allow to switch the workspace\n- Genereate an detailed execution plan according to the {System Prompt|AI Personality|Custom Prompt|UserPrompt|Confirmation Wuestions}\n- Capture the timestamp of the creation and save this\n- Allow the user to add more resources\n- Allow to select the research template\n- Also pickup the user BIO to generate the research customized (if allowed)\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
