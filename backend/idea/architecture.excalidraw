    {
      "id": "FQwffNuQqGI0oefvuYP-D",
      "type": "text",
      "x": 4883.732258814023,
      "y": 6125.242414366297,
      "width": 378.39947509765625,
      "height": 380,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
