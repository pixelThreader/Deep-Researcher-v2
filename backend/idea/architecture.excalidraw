      "boundElements": [],
      "updated": 1771955230675,
      "link": null,
      "locked": false,
      "text": "Generate the Confirmation\nQuestions  for the user\naccording to the research\nand take inputs accordingly\nand based on the user bio\nand personality.\n\nMake the question\ncustomised.\n\nplease add the questions\naccording to the user bio\nand according to the\nresearch template choosen",
      "fontSize": 24,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "7gabG4COpt6RQ6DJ1n2fm",
      "originalText": "Generate the Confirmation Questions  for the user according to the research and take inputs accordingly\nand based on the user bio and personality.\n\nMake the question customised.\n\nplease add the questions according to the user bio and according to the research template choosen",
      "autoResize": true,
      "lineHeight": 1.25
    },
